{
  "expo": {
    "name": "Hugh Manatee",
    "slug": "hugh-manatee",
    "scheme": "hughmanatee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beyondpandora.hughmanatee",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Hugh listens so you can record your memories by voice.",
        "NSCameraUsageDescription": "Camera access is not used by Hugh Manatee. This entry is required because a third-party library (WebRTC) references camera APIs.",
        "NSContactsUsageDescription": "Used only once to pre-fill your name from this phone. Not stored or sent.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.beyondpandora.hughmanatee",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-contacts",
      "expo-av",
      "expo-sqlite",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "04b93c2b-6be7-47a7-9242-a2d51268ef90"
      }
    },
    "owner": "beyondpandora",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/04b93c2b-6be7-47a7-9242-a2d51268ef90"
    }
  }
}
