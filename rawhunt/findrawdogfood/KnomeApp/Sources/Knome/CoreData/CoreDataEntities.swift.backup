// MARK: - Core Data Model Helper
class CoreDataModelManager {
    
    // MARK: - Model Creation
    static func createManagedObjectModel() -> NSManagedObjectModel {
        let model = NSManagedObjectModel()
        
        // Create entities
        let entities = [
            createChatMessageEntity(),
            createJournalEntryEntity(),
            createMoodEntryEntity(),
            createSessionEntity(),
            createUserPreferenceEntity(),
            createGoalEntity(),
            createReminderEntity(),
            createInsightEntity(),
            createAnalyticsEventEntity()
        ]
        
        model.entities = entities
        return model
    }
    
    private static func createChatMessageEntity() -> NSEntityDescription {
        let entity = NSEntityDescription()
        entity.name = "ChatMessageEntity"
        entity.managedObjectClassName = NSStringFromClass(ChatMessageEntity.self)
        
        let idAttribute = NSAttributeDescription()
        idAttribute.name = "id"
        idAttribute.attributeType = .UUIDAttributeType
        idAttribute.isOptional = false
        
        let contentAttribute = NSAttributeDescription()
        contentAttribute.name = "content"
        contentAttribute.attributeType = .stringAttributeType
        contentAttribute.isOptional = false
        
        let isUserAttribute = NSAttributeDescription()
        isUserAttribute.name = "isUser"
        isUserAttribute.attributeType = .booleanAttributeType
        isUserAttribute.defaultValue = false
        
        let timestampAttribute = NSAttributeDescription()
        timestampAttribute.name = "timestamp"
        timestampAttribute.attributeType = .dateAttributeType
        timestampAttribute.isOptional = false
        
        let encryptedContentAttribute = NSAttributeDescription()
        encryptedContentAttribute.name = "encryptedContent"
        encryptedContentAttribute.attributeType = .binaryDataAttributeType
        encryptedContentAttribute.isOptional = true
        
        let metadataAttribute = NSAttributeDescription()
        metadataAttribute.name = "metadata"
        metadataAttribute.attributeType = .stringAttributeType
        metadataAttribute.isOptional = true
        
        entity.properties = [idAttribute, contentAttribute, isUserAttribute, timestampAttribute, encryptedContentAttribute, metadataAttribute]
        
        return entity
    }
    
    private static func createJournalEntryEntity() -> NSEntityDescription {
        let entity = NSEntityDescription()
        entity.name = "JournalEntryEntity"
        entity.managedObjectClassName = NSStringFromClass(JournalEntryEntity.self)
        
        let properties = createCommonProperties() + [
            createStringAttribute("content", required: true),
            createStringAttribute("mood", required: false),
            createStringAttribute("tags", required: false),
            createBinaryAttribute("encryptedContent"),
            createIntAttribute("wordCount"),
            createDoubleAttribute("sentiment")
        ]
        
        entity.properties = properties
        return entity
    }
    
    private static func createMoodEntryEntity() -> NSEntityDescription {
        let entity = NSEntityDescription()
        entity.name = "MoodEntryEntity"
        entity.managedObjectClassName = NSStringFromClass(MoodEntryEntity.self)
        
        let properties = createCommonProperties() + [
            createStringAttribute("mood", required: true),
            createStringAttribute("notes", required: false),
            createIntAttribute("intensity"),
            createStringAttribute("triggers", required: false),
            createStringAttribute("context", required: false)
        ]
        
        entity.properties = properties
        return entity
    }
    
    // Add more entity creation methods as needed...
    
    // MARK: - Helper Methods
    private static func createCommonProperties() -> [NSPropertyDescription] {
        let idAttribute = NSAttributeDescription()
        idAttribute.name = "id"
        idAttribute.attributeType = .UUIDAttributeType
        idAttribute.isOptional = false
        
        let timestampAttribute = NSAttributeDescription()
        timestampAttribute.name = "timestamp"
        timestampAttribute.attributeType = .dateAttributeType
        timestampAttribute.isOptional = false
        
        return [idAttribute, timestampAttribute]
    }
    
    private static func createStringAttribute(_ name: String, required: Bool = false) -> NSAttributeDescription {
        let attribute = NSAttributeDescription()
        attribute.name = name
        attribute.attributeType = .stringAttributeType
        attribute.isOptional = !required
        return attribute
    }
    
    private static func createIntAttribute(_ name: String) -> NSAttributeDescription {
        let attribute = NSAttributeDescription()
        attribute.name = name
        attribute.attributeType = .integer32AttributeType
        attribute.defaultValue = 0
        return attribute
    }
    
    private static func createDoubleAttribute(_ name: String) -> NSAttributeDescription {
        let attribute = NSAttributeDescription()
        attribute.name = name
        attribute.attributeType = .doubleAttributeType
        attribute.defaultValue = 0.0
        return attribute
    }
    
    private static func createBinaryAttribute(_ name: String) -> NSAttributeDescription {
        let attribute = NSAttributeDescription()
        attribute.name = name
        attribute.attributeType = .binaryDataAttributeType
        attribute.isOptional = true
        return attribute
    }
}