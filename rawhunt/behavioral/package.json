{
  "name": "@gohunta/behavioral-science",
  "version": "1.0.0",
  "description": "Comprehensive behavioral science framework for GoHunta.com hunting platform",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:behavioral": "jest --config jest.config.js --testPathPattern=behavioral",
    "test:integration": "jest --config jest.config.js --testPathPattern=integration",
    "lint": "eslint 'src/**/*.{ts,tsx}' --fix",
    "lint:check": "eslint 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,json,md}'",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint:check && npm run format:check && npm run type-check",
    "dev": "concurrently \"npm run build:watch\" \"npm run test:watch\"",
    "start": "node dist/index.js",
    "clean": "rimraf dist coverage",
    "docs": "typedoc --out docs src",
    "benchmark": "node scripts/benchmark.js",
    "analyze": "node scripts/analyze-behavioral-patterns.js"
  },
  "keywords": [
    "behavioral-science",
    "psychology",
    "user-engagement", 
    "habit-formation",
    "gamification",
    "community-building",
    "hunting",
    "dog-training",
    "social-dynamics",
    "seasonal-adaptation"
  ],
  "author": "GoHunta Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gohunta/behavioral-science.git"
  },
  "bugs": {
    "url": "https://github.com/gohunta/behavioral-science/issues"
  },
  "homepage": "https://github.com/gohunta/behavioral-science#readme",
  "dependencies": {
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "rxjs": "^7.8.1",
    "mathjs": "^11.11.0",
    "ml-regression": "^6.1.0",
    "simple-statistics": "^7.8.3",
    "d3": "^7.8.5",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.200",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@types/d3": "^7.4.3",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.2"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./framework": {
      "import": "./dist/framework/index.js",
      "require": "./dist/framework/index.cjs",
      "types": "./dist/framework/index.d.ts"
    },
    "./gamification": {
      "import": "./dist/gamification/index.js",
      "require": "./dist/gamification/index.cjs", 
      "types": "./dist/gamification/index.d.ts"
    },
    "./analytics": {
      "import": "./dist/analytics/index.js",
      "require": "./dist/analytics/index.cjs",
      "types": "./dist/analytics/index.d.ts"
    },
    "./engagement": {
      "import": "./dist/engagement/index.js",
      "require": "./dist/engagement/index.cjs",
      "types": "./dist/engagement/index.d.ts"
    },
    "./community": {
      "import": "./dist/community/index.js",
      "require": "./dist/community/index.cjs",
      "types": "./dist/community/index.d.ts"
    },
    "./seasonal": {
      "import": "./dist/seasonal/index.js",
      "require": "./dist/seasonal/index.cjs",
      "types": "./dist/seasonal/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/tests"],
    "testMatch": [
      "**/__tests__/**/*.+(ts|tsx|js)",
      "**/*.(test|spec).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/*.test.{ts,tsx}",
      "!src/**/__tests__/**/*"
    ],
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "@typescript-eslint/recommended",
      "prettier"
    ],
    "parser": "@typescript-eslint/parser",
    "plugins": ["@typescript-eslint", "import"],
    "rules": {
      "@typescript-eslint/no-unused-vars": "error",
      "@typescript-eslint/explicit-function-return-type": "warn",
      "@typescript-eslint/no-explicit-any": "warn",
      "import/order": ["error", {
        "groups": [
          "builtin",
          "external", 
          "internal",
          "parent",
          "sibling",
          "index"
        ]
      }]
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false
  },
  "config": {
    "behavioral": {
      "testUsers": 1000,
      "testDuration": 30,
      "significanceLevel": 0.05,
      "minimumEffectSize": 0.1
    }
  }
}