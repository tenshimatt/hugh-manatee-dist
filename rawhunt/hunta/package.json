{
  "name": "hunta",
  "version": "1.0.0",
  "description": "Elite Dog Hunting Platform - Offline-first wilderness compatibility",
  "main": "index.js",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && wrangler dev",
    "dev:full": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "test:bdd": "cd tests && cucumber-js features",
    "test:all": "npm run test:bdd",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && wrangler deploy",
    "deploy:dev": "npm run build:frontend && npm run build:backend",
    "deploy:prod": "NODE_ENV=production npm run deploy:dev",
    "tmux:start": "tmux-orchestrator tmux.yml",
    "notion:sync": "cd tools && python3 notion_push.py",
    "logs:tail": "tail -f logs/universal.log",
    "setup": "npm install && cd frontend && npm install && cd ../backend && npm install && cd ../tests && npm install"
  },
  "keywords": [
    "hunting",
    "dogs",
    "gps",
    "offline-first",
    "pwa",
    "cloudflare",
    "wilderness"
  ],
  "author": "Codex H. Archer",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tmux-orchestrator": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hunting-platform/hunta.git"
  },
  "homepage": "https://gohunta.com"
}