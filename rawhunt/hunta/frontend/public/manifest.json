{
  "name": "GoHunta - Elite Dog Hunting Platform",
  "short_name": "GoHunta",
  "description": "Elite dog hunting platform with offline-first wilderness compatibility, GPS tracking, and comprehensive hunt management",
  "keywords": ["hunting", "dogs", "hunting dogs", "GPS", "tracking", "wildlife", "outdoors", "field", "training"],
  "lang": "en-US",
  "dir": "ltr",
  "version": "2.0.0",
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/maskable-icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "start_url": "/?source=pwa",
  "id": "gohunta-app",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "orientation": "portrait-primary",
  "theme_color": "#059669",
  "background_color": "#f0fdf4",
  "categories": ["sports", "lifestyle", "utilities"],
  "shortcuts": [
    {
      "name": "Quick Hunt Log",
      "short_name": "Hunt Log",
      "description": "Quickly log a new hunt with GPS and photos",
      "url": "/quick-log?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-hunt-log.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Dog Profiles",
      "short_name": "Dogs",
      "description": "View and manage your hunting dog profiles",
      "url": "/packs?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-dogs.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Route Planner",
      "short_name": "Routes",
      "description": "Plan hunting routes with GPS waypoints",
      "url": "/routes/new?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-routes.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Training Logs",
      "short_name": "Training",
      "description": "Record training sessions and progress",
      "url": "/training?source=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-training.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/dashboard-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "GoHunta Dashboard - Mobile view showing hunt statistics and quick actions"
    },
    {
      "src": "/screenshots/hunt-log-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Hunt Log Creation - GPS tracking and photo capture for field documentation"
    },
    {
      "src": "/screenshots/dog-profiles-mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Dog Profiles - Comprehensive pack management and training records"
    },
    {
      "src": "/screenshots/dashboard-desktop.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "GoHunta Dashboard - Desktop view with detailed analytics and hunt planning"
    }
  ],
  "prefer_related_applications": false,
  "protocol_handlers": [
    {
      "protocol": "web+gohunta",
      "url": "/share?hunt=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/import-gpx",
      "accept": {
        "application/gpx+xml": [".gpx"],
        "text/xml": [".gpx"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "photos",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },
  "handle_links": "preferred",
  "edge_side_panel": {
    "preferred_width": 400
  },
  "permissions": [
    "geolocation",
    "camera",
    "microphone",
    "storage-access",
    "background-sync"
  ],
  "features": [
    "cross-origin-isolated",
    "offline-capable",
    "gps-tracking",
    "camera-capture",
    "voice-recording",
    "background-sync",
    "push-notifications"
  ],
  "related_applications": [
    {
      "platform": "play",
      "id": "com.gohunta.app",
      "url": "https://play.google.com/store/apps/details?id=com.gohunta.app"
    },
    {
      "platform": "itunes",
      "id": "com.gohunta.app",
      "url": "https://apps.apple.com/app/gohunta/id123456789"
    }
  ],
  "iarc_rating_id": "e58c174a-81d2-5c3c-32cc-34b8de4a52e9"
}