    "performance": {
      "thresholds": {
        "apiResponseTime": 500,
        "pageLoadTime": 3000,
        "memoryUsage": 536870912,
        "concurrentUsers": 50,
        "offlineSyncTime": 2000,
        "gpsFixTime": 10000,
        "photoCaptureTime": 3000
      },
      "loadTesting": {
        "concurrentUsers": [10, 25, 50, 75, 100],
        "testDuration": 30000,
        "rampUpTime": 10000
      },
      "memoryTesting": {
        "maxRecords": 1000,
        "recordSize": 50000,
        "iterationsPerTest": 10
      }
    },
    "reporting": {
      "formats": ["html", "json", "junit"],
      "outputPath": "./reports/",
      "screenshots": {
        "mode": "only-on-failure",
        "fullPage": true
      },
      "videos": {
        "mode": "retain-on-failure",
        "size": { "width": 1280, "height": 720 }
      },
      "traces": {
        "mode": "retain-on-failure"
      }
    },
    "cleanup": {
      "clearIndexedDB": true,
      "clearLocalStorage": true,
      "clearSessionStorage": true,
      "resetNetworkConditions": true,
      "stopGPSTracking": true,
      "closeBrowserContexts": true
    },
    "notifications": {
      "slack": {
        "enabled": false,
        "webhook": "${SLACK_WEBHOOK_URL}",
        "channels": {
          "success": "#testing-success",
          "failure": "#testing-alerts"
        }
      },
      "email": {
        "enabled": false,
        "recipients": ["team@gohunta.com"],
        "smtp": {
          "host": "smtp.gmail.com",
          "port": 587,
          "secure": false
        }
      }
    }
