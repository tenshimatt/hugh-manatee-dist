{
  "testConfiguration": {
    "environment": {
      "development": {
        "apiBaseUrl": "http://localhost:8787",
        "pwaBaseUrl": "http://localhost:5173",
        "gohuntaUrl": "http://localhost:5173",
        "rawgleUrl": "http://localhost:8080",
        "database": "local",
        "timeout": 30000
      },
      "staging": {
        "apiBaseUrl": "https://staging-api.gohunta.com",
        "pwaBaseUrl": "https://staging.gohunta.com",
        "gohuntaUrl": "https://staging.gohunta.com",
        "rawgleUrl": "https://staging.rawgle.com",
        "database": "staging",
        "timeout": 45000
      },
      "production": {
        "apiBaseUrl": "https://api.gohunta.com",
        "pwaBaseUrl": "https://gohunta.com",
        "gohuntaUrl": "https://gohunta.com",
        "rawgleUrl": "https://rawgle.com",
        "database": "production-readonly",
        "timeout": 60000
      }
    },
    "testSuites": {
      "api-integration": {
        "description": "Frontend-backend API communication tests",
        "files": ["api-integration.test.js"],
        "timeout": 900000,
        "retries": 2,
        "parallel": false,
        "tags": ["@api", "@integration", "@smoke"],
        "requirements": {
          "backend": true,
          "database": true,
          "authentication": true
        }
      },
      "pwa-integration": {
        "description": "Progressive Web App functionality tests",
        "files": ["pwa-integration.test.js"],
        "timeout": 1200000,
        "retries": 1,
        "parallel": true,
        "tags": ["@pwa", "@integration", "@offline"],
        "requirements": {
          "frontend": true,
          "serviceWorker": true,
          "indexedDB": true
        }
      },
      "cross-platform": {
        "description": "Platform detection and compatibility tests",
        "files": ["cross-platform-integration.test.js"],
        "timeout": 600000,
        "retries": 1,
        "parallel": true,
        "tags": ["@cross-platform", "@integration"],
        "requirements": {
          "frontend": true,
          "multipleUrls": true
        }
      },
      "field-scenarios": {
        "description": "Real-world hunting scenario tests",
        "files": ["field-usage-scenarios.test.js"],
        "timeout": 1500000,
        "retries": 1,
        "parallel": false,
        "tags": ["@field", "@integration", "@e2e"],
        "requirements": {
          "frontend": true,
          "gps": true,
          "camera": true,
          "microphone": true
        }
      },
      "edge-cases": {
        "description": "Edge case and stress testing",
        "files": ["edge-case-scenarios.test.js"],
        "timeout": 1800000,
        "retries": 1,
        "parallel": false,
        "tags": ["@edge-cases", "@stress", "@integration"],
        "requirements": {
          "frontend": true,
          "networkControl": true,
          "batteryApi": true
        }
      },
      "performance": {
        "description": "Performance and load testing",
        "files": ["performance-testing.js"],
        "timeout": 1200000,
        "retries": 0,
        "parallel": false,
        "tags": ["@performance", "@load", "@benchmark"],
        "requirements": {
          "frontend": true,
          "backend": true,
          "loadTesting": true
        }
      }
    },
    "browsers": {
      "chromium": {
        "enabled": true,
        "headless": true,
