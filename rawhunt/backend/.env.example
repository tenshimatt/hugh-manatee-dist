# Rawgle Platform Environment Configuration

# Database (if using local development)
# DATABASE_URL=your_database_url_here

# JWT Secret for token signing
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random

# Cloudflare Workers Environment
ENVIRONMENT=development
# ENVIRONMENT=production

# Admin Bypass Configuration
# Set to 'true' to allow any authenticated user admin access (DEVELOPMENT ONLY!)
BYPASS_AUTH=true

# Specific admin emails (comma-separated)
ADMIN_EMAILS=admin@rawgle.com,dev@rawgle.com

# Specific admin user IDs (comma-separated)
ADMIN_USER_IDS=

# OpenAI API Key (for AI medical consultations)
OPENAI_API_KEY=

# API Version
API_VERSION=v1

# Rate Limiting
RATE_LIMIT_ENABLED=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5175,http://localhost:3000

# Logging Level
LOG_LEVEL=info