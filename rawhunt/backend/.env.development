# Rawgle Platform - Development Environment Configuration
#
# This file contains the environment variables needed for local development.
# Copy this file to `.env` and fill in your actual API key values.

# =============================================================================
# CRITICAL: ANTHROPIC API KEY SETUP REQUIRED
# =============================================================================
# 
# The Claude AI chat integration requires a valid Anthropic API key.
# 
# TO COMPLETE SETUP:
# 1. Get an API key from: https://console.anthropic.com/
# 2. Replace the placeholder below with your actual key
# 3. Or use wrangler secrets: `npx wrangler secret put ANTHROPIC_API_KEY`
#
# IMPORTANT: Never commit real API keys to version control!
#
# Current status: PLACEHOLDER KEY - REPLACE WITH REAL KEY
ANTHROPIC_API_KEY=sk-ant-api03-DEV_KEY_PLACEHOLDER_REPLACE_WITH_ACTUAL_KEY

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=sqlite://./dev.db

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=dev-jwt-secret-key-change-in-production
ENVIRONMENT=development
BYPASS_AUTH=true

# =============================================================================
# CORS & API CONFIGURATION  
# =============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178
API_VERSION=v1
LOG_LEVEL=info

# =============================================================================
# PAWS TOKEN SYSTEM
# =============================================================================
PAWS_EARNING_RATES={"order_completion": 10, "review_submission": 5, "referral": 25}

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# ADMIN ACCESS
# =============================================================================
ADMIN_EMAILS=admin@rawgle.com,dev@rawgle.com
ADMIN_USER_IDS=