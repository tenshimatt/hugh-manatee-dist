# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# D1 Database
RAWGLE_D1_DATABASE_ID=your-d1-database-id

# KV Namespaces
RAWGLE_KV_NAMESPACE_ID=your-kv-namespace-id
RAWGLE_KV_PREVIEW_ID=your-kv-preview-id
SESSIONS_KV_NAMESPACE_ID=your-sessions-namespace-id
SESSIONS_KV_PREVIEW_ID=your-sessions-preview-id

# R2 Storage
R2_ACCOUNT_ID=your-r2-account-id

# Solana Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_MASTER_WALLET=E9mnWdbp97pGaUTGRP743KhppWkYzkagWo7JM3hRJsHA
SOLANA_PRIVATE_KEY=your-solana-private-key

# PAWS Token Configuration
PAWS_EXCHANGE_RATE=1000
PAWS_TOKEN_MINT=your-paws-token-mint-address

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRY=24h

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=debug
RATE_LIMIT_PER_MINUTE=60
MAX_PAYLOAD_SIZE=10485760
SESSION_TIMEOUT_HOURS=24
MAX_DAILY_PAWS=500

# External Services (Optional)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
DATADOG_API_KEY=your-datadog-api-key

# Email Service (Optional)
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@rawgle.com

# Image Processing
MAX_IMAGE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# AI Configuration
AI_CONFIDENCE_THRESHOLD=0.7
MAX_AI_TOKENS=1000

# Analytics
ANALYTICS_SAMPLING_RATE=0.1

# Feature Flags
ENABLE_NFT_MINTING=true
ENABLE_AI_CONSULTATIONS=true
ENABLE_MARKETPLACE=false
ENABLE_SUBSCRIPTION_FEATURES=true