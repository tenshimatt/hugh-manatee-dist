    "monitor:start": "node monitoring/start-monitoring.js",
    "monitor:dashboard": "node monitoring/dashboard-server.js",
    "benchmark": "node benchmarks/run-benchmarks.js",
    "validate": "node tools/validate-schema.js",
    "backup": "node tools/create-backup.js",
    "analyze": "node tools/analyze-performance.js",
    "setup": "node tools/setup-database.js"
