    "fs-extra": "^11.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.2",
    "ora": "^8.0.1",
    "table": "^6.8.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
