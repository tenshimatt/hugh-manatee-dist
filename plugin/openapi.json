"openapi": "3.1.0",
"info": {
  "title": "Pandora Plugin",
  "description": "Execute Python code remotely.",
  "version": "1.0.0"
},
"servers": [
  {
    "url": "https://api.beyondpandora.com"
  }
],
"paths": {
  "/chatgpt_submit": {
    "post": {
      "summary": "Execute code",
      "operationId": "runCode",
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "code": {
                  "type": "string"
                }
              },
              "required": ["code"]
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Execution result",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "output": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
