{
  "name": "rawgle-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "playwright test",
    "test:skip-servers": "SKIP_WEBSERVER=true playwright test",
    "test:fast": "SKIP_WEBSERVER=true playwright test --timeout=10000 --grep=\"Level 1\"",
    "test:medium": "SKIP_WEBSERVER=true playwright test --timeout=15000 --grep=\"Level 2\"",
    "test:full": "SKIP_WEBSERVER=true playwright test --timeout=60000",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:e2e": "cypress open",
    "test:e2e:run": "cypress run",
    "test:e2e:ci": "start-server-and-test dev http://localhost:3000 test:e2e:run",
    "test:a11y": "pa11y-ci --sitemap http://localhost:3000/sitemap.xml",
    "test:lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "test:all": "npm run test:unit && npm run test:e2e:ci && npm run test",
    "quality-check": "node quality-check.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "cf:dev": "wrangler pages dev --compatibility-date=2024-01-01 -- npm run dev",
    "cf:deploy": "npm run build && wrangler pages deploy ./out"
  },
  "dependencies": {
