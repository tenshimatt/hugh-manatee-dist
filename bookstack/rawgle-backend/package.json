{
  "name": "rawgle-backend",
  "version": "1.0.0",
  "description": "RAWGLE Backend API - Raw pet food management platform",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverage-directory=coverage --coverage-reporters=text,lcov,html",
    "test:unit": "jest tests/unit --coverage --collect-coverage-from='src/**/*.{ts,js}' --coverage-directory=coverage/unit",
    "test:integration": "jest tests/integration --coverage --collect-coverage-from='src/**/*.{ts,js}' --coverage-directory=coverage/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:e2e:headed": "playwright test tests/e2e --headed",
    "test:e2e:debug": "playwright test tests/e2e --debug",
    "test:accessibility": "playwright test tests/accessibility",
    "test:accessibility:report": "playwright show-report accessibility-results",
    "test:api": "newman run tests/postman/rawgle-api.json -e tests/postman/test-env.json",
    "test:load": "artillery run tests/load/course-enrollment-load.yml",
    "test:load:extended": "artillery run tests/load/course-enrollment-load.yml --environment production",
    "test:load:video": "artillery run tests/load/video-streaming-load.yml",
    "test:load:webinar": "artillery run tests/load/webinar-registration-burst.yml",
    "test:security": "npm audit --audit-level=moderate && snyk test",
    "test:db": "jest tests/database",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:accessibility",
    "test:ci": "npm run lint && npm run type-check && npm run test:all",
    "test:performance": "npm run test:load && node scripts/performance-analysis.js",
    "test:smoke": "jest tests/smoke --testTimeout=30000",
    "test:contract": "pact-broker can-i-deploy --participant=rawgle-backend",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:status": "tsx src/scripts/migrate.ts status",
    "migrate:reset": "tsx src/scripts/migrate.ts reset",
    "migrate:validate": "tsx src/scripts/migrate.ts validate",
    "migrate:create": "tsx src/scripts/migrate.ts create",
    "db:reset": "tsx src/scripts/resetDb.ts",
    "db:init": "tsx src/scripts/init-database.ts",
    "seed": "tsx src/scripts/seed.ts",
    "db:admin": "tsx src/scripts/database-admin-tools.ts",
    "db:health": "tsx src/scripts/database-admin-tools.ts health",
    "db:maintenance": "tsx src/scripts/database-admin-tools.ts maintenance",
    "db:stats": "tsx src/scripts/database-admin-tools.ts stats",
    "db:report": "tsx src/scripts/database-admin-tools.ts report",
    "db:migrate-incremental": "tsx src/scripts/run-incremental-migration.ts",
    "db:backup": "tsx src/scripts/backup-disaster-recovery.ts",
    "db:backup:incremental": "tsx src/scripts/backup-disaster-recovery.ts incremental",
    "db:restore": "tsx src/scripts/backup-disaster-recovery.ts restore",
    "db:monitor": "tsx src/scripts/backup-disaster-recovery.ts monitor",
    "db:recovery-plan": "tsx src/scripts/backup-disaster-recovery.ts recovery-plan"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@types/cookie-parser": "^1.4.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "openai": "^5.19.1",
    "pg": "^8.12.0",
    "redis": "^4.7.0",
    "sharp": "^0.33.5",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.3",
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.40.0",
    "@testcontainers/postgresql": "^11.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.5.4",
    "@types/nodemailer": "^6.4.16",
    "@types/pg": "^8.11.8",
    "@types/sharp": "^0.32.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.4.0",
    "@typescript-eslint/parser": "^8.4.0",
    "artillery": "^2.0.24",
    "axe-core": "^4.8.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0",
    "jsdom": "^26.1.0",
    "k6": "^0.0.0",
    "newman": "^6.2.1",
    "nodemon": "^3.1.4",
    "playwright": "^1.40.0",
    "prettier": "^3.3.3",
    "snyk": "^1.1274.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "keywords": [
    "rawgle",
    "pet food",
    "raw feeding",
    "pet health",
    "api",
    "nodejs",
    "typescript"
  ],
  "author": "RAWGLE Development Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
