{
  "name": "hunta-backend",
  "version": "1.0.0",
  "description": "Hunta Backend - Cloudflare Workers",
  "main": "workers/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply hunta-db",
    "db:migrate:prod": "wrangler d1 migrations apply hunta-db --env production",
    "db:seed": "wrangler d1 execute hunta-db --file=./schemas/seed.sql",
    "test": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20241024.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "wrangler": "^3.78.12",
    "vitest": "^2.1.5"
  }
}