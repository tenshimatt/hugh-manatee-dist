{
  "name": "hunta-tests",
  "version": "1.0.0",
  "description": "Hunta BDD Test Suite",
  "type": "module",
  "scripts": {
    "test": "cucumber-js features",
    "test:watch": "cucumber-js features --watch",
    "test:parallel": "cucumber-js features --parallel 4",
    "test:smoke": "cucumber-js features --tags @smoke",
    "test:integration": "cucumber-js features --tags @integration",
    "test:e2e": "cucumber-js features --tags @e2e",
    "test:offline": "cucumber-js features --tags @offline",
    "test:mobile": "cucumber-js features --tags @mobile",
    "test:report": "cucumber-js features --format html:reports/cucumber-report.html",
    "test:ci": "cucumber-js features --format json:reports/cucumber-report.json"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "playwright": "^1.40.1",
    "axios": "^1.6.2",
    "chai": "^4.3.10",
    "expect": "^29.7.0"
  },
  "devDependencies": {
    "@cucumber/html-formatter": "^21.0.0",
    "@cucumber/json-formatter": "^8.0.1"
  },
  "cucumber": {
    "requireModule": [
      "ts-node/register"
    ],
    "require": [
      "steps/**/*.js"
    ],
    "format": [
      "progress-bar",
      "html:reports/cucumber-report.html"
    ],
    "formatOptions": {
      "snippetInterface": "async-await"
    }
  }
}